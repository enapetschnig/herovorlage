# =============================================================================
# HeatFlow — Environment Variables (Dev)
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git. .gitignore already excludes it.
# =============================================================================

# -----------------------------------------------------------------------------
# Node environment
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=HeatFlow

# -----------------------------------------------------------------------------
# Auth (NextAuth v5)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_TO_A_RANDOM_32_BYTE_BASE64_STRING
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# -----------------------------------------------------------------------------
# Database (Postgres)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://heatflow:heatflow@localhost:5432/heatflow

# -----------------------------------------------------------------------------
# Redis (for BullMQ queues, rate-limiting, cache)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Meilisearch (full-text search)
# -----------------------------------------------------------------------------
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_MASTER_KEY=heatflow_dev_master_key_change_me

# -----------------------------------------------------------------------------
# S3 / MinIO (file storage)
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-central-1
S3_ACCESS_KEY_ID=heatflow
S3_SECRET_ACCESS_KEY=heatflow123
S3_BUCKET_FILES=heatflow-files
S3_BUCKET_DOCUMENTS=heatflow-documents
S3_FORCE_PATH_STYLE=true

# -----------------------------------------------------------------------------
# Email (SMTP via Mailpit in dev, Resend in prod)
# -----------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="HeatFlow <noreply@heatflow.local>"

# In production, use Resend instead of SMTP:
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# AI (FlowAI, Module M12)
# -----------------------------------------------------------------------------
# Leave empty in dev if not using AI features yet.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Monitoring (optional in dev)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
POSTHOG_KEY=
POSTHOG_HOST=https://eu.posthog.com

# -----------------------------------------------------------------------------
# Google Services (for Address Autocomplete, optional)
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Feature flags (global overrides for dev)
# -----------------------------------------------------------------------------
ENABLE_DEBUG_ROUTES=true
