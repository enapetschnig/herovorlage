{
  "name": "@heatflow/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts",
    "./seed": "./src/seed.ts"
  },
  "scripts": {
    "lint": "echo 'no lint'",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/seed.ts",
    "db:apply-via-mgmt": "tsx src/apply-via-management-api.ts",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "@heatflow/utils": "workspace:*",
    "drizzle-orm": "0.36.4",
    "postgres": "3.4.5",
    "ulid": "2.3.0"
  },
  "devDependencies": {
    "drizzle-kit": "0.28.1",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "dotenv": "16.4.5",
    "@types/node": "22.8.7"
  }
}
