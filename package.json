{
  "name": "heatflow",
  "version": "0.1.0",
  "private": true,
  "description": "HeatFlow — Next-Generation Handwerkersoftware für Wärmepumpen-Installationsbetriebe",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.11.0",
    "pnpm": ">=9.12.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml,yml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yaml,yml}\" --ignore-path .gitignore",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:push": "pnpm --filter @heatflow/db db:push",
    "db:migrate": "pnpm --filter @heatflow/db db:migrate",
    "db:seed": "pnpm --filter @heatflow/db db:seed",
    "db:studio": "pnpm --filter @heatflow/db db:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d"
  },
  "devDependencies": {
    "@types/node": "22.8.7",
    "next": "15.1.0",
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.8",
    "turbo": "2.2.3",
    "typescript": "5.6.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19",
        "react-dom": "19"
      }
    }
  }
}
